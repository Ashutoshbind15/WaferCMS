{
  "name": "portfolio-repo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:cms-server": "pnpm --filter cms-server run dev",
    "dev:cms-client": "pnpm --filter cms-client run dev",
    "dev:portfolio": "pnpm --filter portfolio run dev",
    "typecheck:cms-server": "pnpm --workspace-root exec tsc --project cms-server/tsconfig.json --noEmit --ignoreDeprecations 6.0",
    "typecheck:portfolio": "pnpm --workspace-root exec tsc --project portfolio/tsconfig.json --noEmit --ignoreDeprecations 6.0",
    "typecheck:db": "pnpm --filter @packages/db run typecheck",
    "typecheck:diagram": "pnpm --filter @packages/diagram run typecheck",
    "test:diagram": "node --import tsx --test --test-reporter=spec tests/diagramming.test.ts",
    "test:diagram:coverage": "node --import tsx --test --test-reporter=spec --experimental-test-coverage --test-coverage-lines=95 --test-coverage-include \"packages/diagram/**/*.ts\" --test-coverage-include \"cms-client/src/components/diagram-canvas/coordinate-utils.ts\" --test-coverage-include \"cms-client/src/components/diagram-canvas/hit-test.ts\" --test-coverage-include \"cms-client/src/components/diagram-canvas/useCanvasReducer.ts\" --test-coverage-include \"cms-client/src/pages/diagrams/diagram-utils.ts\" --test-coverage-exclude \"packages/diagram/types.ts\" --test-coverage-exclude \"tests/**/*.ts\" tests/diagramming.test.ts",
    "db:generate": "pnpm --filter @packages/db run generate",
    "db:migrate": "pnpm --filter @packages/db run migrate",
    "db:push": "pnpm --filter @packages/db run push",
    "db:studio": "pnpm --filter @packages/db run studio",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "25.5.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
