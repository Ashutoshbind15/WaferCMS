{
  "name": "wafercms",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --parallel --filter @packages/cms-db --filter @packages/storage --filter @wafercms/rich-text --filter cms-server --filter cms-client run dev",
    "dev:server": "pnpm --parallel --filter @packages/cms-db --filter @packages/storage --filter cms-server run dev",
    "dev:client": "pnpm --parallel --filter @wafercms/rich-text --filter cms-client run dev",
    "build:server": "pnpm --filter @packages/cms-db --filter @packages/storage --filter cms-server run build",
    "build:client": "pnpm --filter @wafercms/rich-text --filter cms-client run build",
    "typecheck:server": "pnpm --filter @packages/cms-db --filter @packages/storage --filter cms-server run typecheck",
    "typecheck:rich-text": "pnpm --filter @wafercms/rich-text run typecheck",
    "typecheck:db": "pnpm --filter @packages/cms-db run typecheck",
    "db:generate": "pnpm --filter @packages/cms-db run generate",
    "db:migrate": "pnpm --filter @packages/cms-db run build && pnpm --filter @packages/cms-db run migrate",
    "db:push": "pnpm --filter @packages/cms-db run push",
    "db:studio": "pnpm --filter @packages/cms-db run studio",
    "format": "prettier --write .",
    "licenses:notices:server": "node scripts/generate-third-party-notices.mjs --filter cms-server... --component cms-server --out dist/licenses/cms-server-THIRD_PARTY_NOTICES",
    "licenses:notices:client": "node scripts/generate-third-party-notices.mjs --filter cms-client... --component cms-client --out dist/licenses/cms-client-THIRD_PARTY_NOTICES",
    "licenses:notices": "pnpm run licenses:notices:server && pnpm run licenses:notices:client"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@quantco/pnpm-licenses": "2.4.2",
    "@types/node": "25.5.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2"
  }
}
