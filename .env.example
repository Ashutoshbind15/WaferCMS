# docker-compose (postgres)
POSTGRES_PASSWORD=mypassword
POSTGRES_USER=postgres

# Published host ports (optional)
CMS_SERVER_PORT=3001
CMS_CLIENT_PORT=8080

# cms-server — public origin browsers use to reach the API / file URLs
CMS_PUBLIC_BASE_URL=http://localhost:3001
CMS_IMAGE_MAX_BYTES=20971520
CMS_IMAGE_MAX_DIMENSION=4096
CMS_API_KEY_PEPPER=
CMS_REQUIRE_API_KEY=true
# Better Auth secret (>=32 random chars; openssl rand -base64 32)
BETTER_AUTH_SECRET=
# Optional override; defaults to CMS_PUBLIC_BASE_URL
# BETTER_AUTH_URL=http://localhost:3001
# Origin of the admin UI (must match how you open cms-client)
CORS_ORIGIN=http://localhost:8080
COOKIE_SECURE=false
CMS_FIRST_USER_LOCK_KEY=1234567890

# First admin on cms-server start (can be unset after first run)
# CMS_BOOTSTRAP_ADMIN_USERNAME=
# CMS_BOOTSTRAP_ADMIN_PASSWORD=

# AI item drafts (optional). Off by default - no OpenRouter setup needed.
# Same flag name on both sides; client needs VITE_.
# CMS_AI_DRAFTS_ENABLED=true
# VITE_CMS_AI_DRAFTS_ENABLED=true
# OPENROUTER_API_KEY=
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# rustfs (object storage)
RUSTFS_ACCESS_KEY_ID=rustfsadmin
RUSTFS_SECRET_ACCESS_KEY=rustfsadmin
RUSTFS_BUCKET=cms-files
AWS_REGION=us-east-1

# cms-client — Vite env, applied at image build time (rebuild after changing)
VITE_CMS_API_BASE=http://localhost:3001
