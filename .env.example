# docker-compose (postgres)
POSTGRES_PASSWORD=mypassword
POSTGRES_USER=postgres

# Published host ports (optional)
CMS_SERVER_PORT=3001
CMS_CLIENT_PORT=8080

# cms-server — public origin browsers use to reach the API / file URLs
CMS_PUBLIC_BASE_URL=http://localhost:3001
CMS_IMAGE_MAX_BYTES=20971520
CMS_IMAGE_MAX_DIMENSION=4096
CMS_API_KEY_PEPPER=
CMS_REQUIRE_API_KEY=true
AUTH_SECRET=
# Origin of the admin UI (must match how you open cms-client)
CORS_ORIGIN=http://localhost:8080
COOKIE_SECURE=false

# rustfs (object storage)
RUSTFS_ACCESS_KEY_ID=rustfsadmin
RUSTFS_SECRET_ACCESS_KEY=rustfsadmin
RUSTFS_BUCKET=cms-files
AWS_REGION=us-east-1

# cms-client — Vite env, applied at image build time (rebuild after changing)
VITE_CMS_API_BASE=http://localhost:3001
