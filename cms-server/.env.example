CMS_DATABASE_URL=postgresql://postgres:mypassword@localhost:5432/cms

# Public origin of cms-server as seen by browsers/integrators. Used to build
# stable asset URLs (`{CMS_PUBLIC_BASE_URL}/files/{id}`) returned in API
# responses. Put a CDN/reverse proxy in front of this in production and cache
# `GET /files/*` for public assets.
CMS_PUBLIC_BASE_URL=http://localhost:3001

# On-the-fly image transforms (GET /files/:id?w=&h=&fit=&format=webp&q=).
# Sources larger than this are rejected with 413 when a transform is requested.
CMS_IMAGE_MAX_BYTES=20971520
# Cap for requested w/h and output pixel dimensions.
CMS_IMAGE_MAX_DIMENSION=4096

RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY_ID=rustfsadmin
RUSTFS_SECRET_ACCESS_KEY=rustfsadmin
RUSTFS_BUCKET=cms-files
AWS_REGION=us-east-1

# M2M API key auth (unchanged for portfolio/consumers)
CMS_API_KEY_PEPPER=
CMS_REQUIRE_API_KEY=true

# Better Auth (admin UI session cookies). Use >=32 random chars
# (e.g. openssl rand -base64 32).
BETTER_AUTH_SECRET=
# Optional override; defaults to CMS_PUBLIC_BASE_URL
# BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
CMS_FIRST_USER_LOCK_KEY=1234567890

# Remote MCP resource server (OAuth 2.1). Off by default.
# Audience / resource identifier is `{CMS_PUBLIC_BASE_URL}/mcp`.
# Login + consent pages live on CORS_ORIGIN (/login, /consent).
# Behind a reverse proxy: forward Host/X-Forwarded-Proto, use HTTPS public URLs,
# and set COOKIE_SECURE=true so OAuth cookies work cross-site if needed.
# CMS_MCP_ENABLED=true

# First admin on server start (no-op once any user exists; unset after first run):
# CMS_BOOTSTRAP_ADMIN_USERNAME=
# CMS_BOOTSTRAP_ADMIN_PASSWORD=

# Local alternative: pnpm --filter cms-server bootstrap-admin -- --username <name>

# AI item drafts (optional). Off by default — no OpenRouter setup needed.
# When true, OPENROUTER_API_KEY is required and POST /collections/:id/ai/draft is mounted.
# CMS_AI_DRAFTS_ENABLED=true
# OPENROUTER_API_KEY=
# Optional OpenRouter model id (default: openai/gpt-4o-mini)
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
