# Copy to deploy/expose-caddy/.env and fill in real values.
# Hostnames should share a registrable site (e.g. cms.example.com + api.example.com)
# so admin session cookies can stay SameSite=Lax.

# --- Edge (Caddy) ---
CMS_ADMIN_HOST=cms.example.com
CMS_API_HOST=api.example.com
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443

# --- Postgres (required by base compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password

# --- Object storage (required; do not use rustfsadmin in production) ---
RUSTFS_ACCESS_KEY_ID=replace-with-strong-access-key
RUSTFS_SECRET_ACCESS_KEY=replace-with-strong-secret-key
RUSTFS_BUCKET=cms-files
AWS_REGION=us-east-1
# Console is off in the expose overlay by default
# RUSTFS_CONSOLE_ENABLE=false

# --- Public HTTPS origins (must match the hostnames above) ---
CMS_PUBLIC_BASE_URL=https://api.example.com
# Optional override; defaults to CMS_PUBLIC_BASE_URL inside the app
# BETTER_AUTH_URL=https://api.example.com
CORS_ORIGIN=https://cms.example.com

# cms-client runtime config (written to /config.js on container start; no image rebuild)
CMS_API_BASE=https://api.example.com

# --- Secrets (required for production / fail-closed startup) ---
# openssl rand -base64 32
BETTER_AUTH_SECRET=
CMS_API_KEY_PEPPER=
CMS_REQUIRE_API_KEY=true
COOKIE_SECURE=true

# --- First admin (set once, then remove these lines and recreate the server container) ---
# CMS_BOOTSTRAP_ADMIN_USERNAME=admin
# CMS_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password
CMS_FIRST_USER_LOCK_KEY=replace-with-random-lock-key

# --- Optional AI (same names on server + cms-client container) ---
# CMS_AI_DRAFTS_ENABLED=false
# CMS_AI_AGENT_ENABLED=false
# OPENROUTER_API_KEY=
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
